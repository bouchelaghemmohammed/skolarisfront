@page "/forgot-password"
@using Skolaris.Client.Components.Layout
@layout LoginLayout
@rendermode InteractiveServer

@inject HttpClient Http
@inject NavigationManager Navigation

<div class="login-page">
    <div class="login-card">
        <div class="logo-row">
            <div class="logo">S</div>
            <span style="font-size:20px; font-weight:700; color:#1565c0;">Skolaris</span>
        </div>

        <h1 style="font-size:22px; margin-top:20px; color:#1565c0;">Mot de passe oublié</h1>
        <p class="subtitle">Entrez votre courriel pour recevoir un lien de réinitialisation.</p>

        @if (!submitted)
        {
            <EditForm Model="model" OnValidSubmit="Submit">
                <DataAnnotationsValidator />

                <div class="form-group">
                    <label>Courriel</label>
                    <InputText class="form-control" @bind-Value="model.Email" placeholder="votre@courriel.com" />
                    <ValidationMessage For="@(() => model.Email)" />
                </div>

                @if (!string.IsNullOrEmpty(errorMessage))
                {
                    <div class="error-message">@errorMessage</div>
                }

                <button type="submit" class="btn-login" disabled="@isLoading">
                    @(isLoading ? "Envoi en cours..." : "Envoyer le lien")
                </button>
            </EditForm>
        }
        else
        {
            <div class="success-box">
                <div style="font-size:40px; margin-bottom:12px;">✉️</div>
                <p>
                    @if (devToken != null)
                    {
                        <span>
                            <strong>Mode développement</strong> — SMTP non configuré.<br />
                            Votre token de réinitialisation :<br />
                            <code
                            style="background:#e3f2fd; padding:6px 10px; border-radius:6px; display:inline-block; margin-top:8px; word-break:break-all;">@devToken</code><br />
                            <a href="/reset-password?token=@devToken"
                                   style="color:#1976d2; display:inline-block; margin-top:10px;">
                                Cliquer ici pour réinitialiser
                            </a>
                        </span>
                    }
                    else
                    {
                        <span>Un courriel de réinitialisation a été envoyé si votre adresse est enregistrée.</span>
                    }
                </p>
            </div>
        }

        <a href="/login" class="forgot-link" style="margin-top:16px; display:block; color:#1976d2;">
            ← Retour à la connexion
        </a>
    </div>
</div>

@code {
    private FormModel model = new();
    private bool submitted = false;
    private bool isLoading = false;
    private string errorMessage = "";
    private string? devToken = null;

    private async Task Submit()
    {
        isLoading = true;
        errorMessage = "";

        var frontendBase = Navigation.BaseUri.TrimEnd('/');
        var response = await Http.PostAsJsonAsync("api/auth/forgot-password", new
        {
            Email = model.Email,
            FrontendBaseUrl =
frontendBase
        });

        if (response.IsSuccessStatusCode)
        {
            var result = await response.Content.ReadFromJsonAsync<ForgotPasswordResult>();
            devToken = result?.DevToken;
            submitted = true;
        }
        else
        {
            errorMessage = "Une erreur est survenue. Veuillez réessayer.";
        }

        isLoading = false;
    }

    public class FormModel
    {
        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Courriel obligatoire.")]
        [System.ComponentModel.DataAnnotations.EmailAddress(ErrorMessage = "Courriel invalide.")]
        public string Email { get; set; } = "";
    }

    public class ForgotPasswordResult
    {
        public bool Success { get; set; }
        public bool EmailSent { get; set; }
        public string? DevToken { get; set; }
    }
}
