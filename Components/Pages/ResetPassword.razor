@page "/reset-password"
@using Skolaris.Client.Components.Layout
@layout LoginLayout
@rendermode InteractiveServer

@inject HttpClient Http
@inject NavigationManager Navigation

<div class="login-page">
    <div class="login-card">
        <div class="logo-row">
            <div class="logo">S</div>
            <span style="font-size:20px; font-weight:700; color:#1565c0;">Skolaris</span>
        </div>

        <h1 style="font-size:22px; margin-top:20px; color:#1565c0;">Nouveau mot de passe</h1>
        <p class="subtitle">Choisissez un nouveau mot de passe pour votre compte.</p>

        @if (!done)
        {
            <EditForm Model="model" OnValidSubmit="Submit">
                <DataAnnotationsValidator />

                <div class="form-group">
                    <label>Nouveau mot de passe</label>
                    <InputText type="password" class="form-control" @bind-Value="model.NewPassword" />
                    <ValidationMessage For="@(() => model.NewPassword)" />
                </div>

                <div class="form-group">
                    <label>Confirmer le mot de passe</label>
                    <InputText type="password" class="form-control" @bind-Value="model.Confirm" />
                    <ValidationMessage For="@(() => model.Confirm)" />
                </div>

                @if (!string.IsNullOrEmpty(errorMessage))
                {
                    <div class="error-message">@errorMessage</div>
                }

                <button type="submit" class="btn-login" disabled="@isLoading">
                    @(isLoading ? "Mise à jour..." : "Réinitialiser le mot de passe")
                </button>
            </EditForm>
        }
        else
        {
            <div class="success-box">
                <div style="font-size:40px; margin-bottom:12px;">✅</div>
                <p>Mot de passe mis à jour avec succès !</p>
                <a href="/login" class="btn-login"
                       style="display:block; text-decoration:none; margin-top:16px; text-align:center;">
                    Se connecter
                </a>
            </div>
        }
    </div>
</div>

@code {
    [SupplyParameterFromQuery]
    public string? Token { get; set; }

    private FormModel model = new();
    private bool done = false;
    private bool isLoading = false;
    private string errorMessage = "";

    private async Task Submit()
    {
        if (model.NewPassword != model.Confirm)
        {
            errorMessage = "Les mots de passe ne correspondent pas.";
            return;
        }

        if (string.IsNullOrWhiteSpace(Token))
        {
            errorMessage = "Token manquant. Veuillez utiliser le lien de votre courriel.";
            return;
        }

        isLoading = true;
        errorMessage = "";

        var response = await Http.PostAsJsonAsync("api/auth/reset-password", new
        {
            Token,
            NewPassword = model.NewPassword
        });

        if (response.IsSuccessStatusCode)
        {
            done = true;
        }
        else
        {
            errorMessage = "Lien invalide ou expiré. Veuillez faire une nouvelle demande.";
        }

        isLoading = false;
    }

    public class FormModel
    {
        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Mot de passe obligatoire.")]
        [System.ComponentModel.DataAnnotations.MinLength(6, ErrorMessage = "Minimum 6 caractères.")]
        public string NewPassword { get; set; } = "";

        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Confirmation obligatoire.")]
        public string Confirm { get; set; } = "";
    }
}
