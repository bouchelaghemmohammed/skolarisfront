@page "/login"

@using Skolaris.Client.Components.Layout
@layout LoginLayout
@rendermode InteractiveServer

@inject HttpClient Http
@inject NavigationManager Navigation
@inject IJSRuntime JS

<div class="login-page">
    <div class="login-card">

        <div class="logo-row">
            <div class="logo">S</div>
            <span style="font-size:22px; font-weight:700; color:#1565c0;">
                Skolaris
            </span>
        </div>

        <h1>Connexion</h1>
        <p class="subtitle">Bienvenue sur la plateforme scolaire</p>

        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="error-message">
                @errorMessage
            </div>
        }

        <EditForm Model="loginModel" OnSubmit="SeConnecter">
            <DataAnnotationsValidator />

            <div class="form-group">
                <label>Courriel</label>

                <InputText class="form-control" @bind-Value="loginModel.Email" placeholder="admin@gmail.com"
                           disabled="@isLoading" />

                <ValidationMessage For="@(() => loginModel.Email)" />
            </div>

            <div class="form-group">
                <label>Mot de passe</label>

                <InputText type="password" class="form-control" @bind-Value="loginModel.Password" placeholder="123456"
                           disabled="@isLoading" />

                <ValidationMessage For="@(() => loginModel.Password)" />
            </div>

            <button type="submit" class="btn-login" disabled="@isLoading">

                @if (isLoading)
                {
                    <span>Connexion...</span>
                }
                else
                {
                    <span>Se connecter</span>
                }

            </button>

        </EditForm>

        <div style="text-align:center; margin-top:14px;">
            <a href="/forgot-password" class="forgot-link" style="font-size:13px;">
                Mot de passe oublié ?
            </a>
        </div>

    </div>
</div>

@code {

    private LoginModel loginModel = new();

    private string errorMessage = "";

    private bool isLoading = false;

    private async Task SeConnecter()
    {
        if (string.IsNullOrWhiteSpace(loginModel.Email)
            || string.IsNullOrWhiteSpace(loginModel.Password))
        {
            errorMessage = "Courriel et mot de passe obligatoires.";
            return;
        }

        errorMessage = "";
        isLoading = true;

        try
        {
            var response = await Http.PostAsJsonAsync(
                "api/auth/login",
                loginModel
            );

            if (!response.IsSuccessStatusCode)
            {
                errorMessage = "Courriel ou mot de passe invalide.";
                isLoading = false;
                return;
            }

            var user = await response.Content
                .ReadFromJsonAsync<UserResponse>();

            if (user == null)
            {
                errorMessage = "Erreur de connexion.";
                isLoading = false;
                return;
            }

            await JS.InvokeVoidAsync(
                "localStorage.setItem",
                "role",
                user.Role
            );

            await JS.InvokeVoidAsync(
                "localStorage.setItem",
                "nom",
                user.Nom
            );

            await JS.InvokeVoidAsync(
                "localStorage.setItem",
                "userId",
                user.Id.ToString()
            );

            var role = user.Role.Trim().ToUpper();

            if (role == "ADMIN")
                Navigation.NavigateTo("/dashboard-admin");

            else if (role == "ENSEIGNANT")
                Navigation.NavigateTo("/dashboard-enseignant");

            else if (role == "ELEVE")
                Navigation.NavigateTo("/dashboard-eleve");

            else
                errorMessage = "Rôle inconnu.";
        }
        catch
        {
            errorMessage = "Erreur serveur.";
            isLoading = false;
        }
    }

    public class LoginModel
    {
        [System.ComponentModel.DataAnnotations.Required(
            ErrorMessage = "Courriel obligatoire.")]
        public string Email { get; set; } = "";

        [System.ComponentModel.DataAnnotations.Required(
            ErrorMessage = "Mot de passe obligatoire.")]
        public string Password { get; set; } = "";
    }

    public class UserResponse
    {
        public int Id { get; set; }

        public string Nom { get; set; } = "";

        public string Email { get; set; } = "";

        public string Role { get; set; } = "";
    }
}