@* HOR-08 — Emploi du temps — Vue Enseignant *@
@page "/enseignant/emploi-du-temps"
@rendermode InteractiveServer
@inject HttpClient Http
@inject IJSRuntime JS
@using System.Net.Http.Json

<h3>Mes créneaux</h3>
<p class="text-muted">Votre emploi du temps personnel.</p>

@if (creneaux == null)
{
    <p>Chargement...</p>
}
else if (!creneaux.Any())
{
    <div class="alert alert-info">Aucun créneau assigné cette semaine.</div>
}
else
{
    @* Résumé *@
    <div class="d-flex gap-3 mb-3">
        <div class="card text-center px-3 py-2 border-success">
            <div class="fs-4 fw-bold text-success">@creneaux.Count</div>
            <div class="small text-muted">Séances</div>
        </div>
        <div class="card text-center px-3 py-2">
            <div class="fs-4 fw-bold">@TotalHeures</div>
            <div class="small text-muted">Heures / sem.</div>
        </div>
        <div class="card text-center px-3 py-2">
            <div class="fs-4 fw-bold">@creneaux.Select(c => c.GroupeNom).Distinct().Count()</div>
            <div class="small text-muted">Groupe(s)</div>
        </div>
    </div>

    <div class="table-responsive">
        <table class="table table-striped table-bordered">
            <thead class="table-dark">
                <tr>
                    <th>Jour</th>
                    <th>Cours</th>
                    <th>Groupe</th>
                    <th>Horaire</th>
                    <th>Salle</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var c in creneaux.OrderBy(x => x.JourSemaine).ThenBy(x => TimeSpan.Parse(x.HeureDebut)))
                {
                    <tr>
                        <td><strong>@JourLabel(c.JourSemaine)</strong></td>
                        <td>@c.CoursNom</td>
                        <td><span class="badge bg-secondary">@c.GroupeNom</span></td>
                        <td>@c.HeureDebut – @c.HeureFin</td>
                        <td>@(c.Salle ?? "—")</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@code {
    private List<CreneauDto>? creneaux;

    private static readonly Dictionary<int, string> Jours = new()
    {
        [1] = "Lundi", [2] = "Mardi", [3] = "Mercredi", [4] = "Jeudi", [5] = "Vendredi"
    };
    private string JourLabel(int j) => Jours.TryGetValue(j, out var l) ? l : j.ToString();

    private string TotalHeures
    {
        get
        {
            if (creneaux == null) return "0";
            double total = 0;
            foreach (var c in creneaux)
            {
                if (TimeSpan.TryParse(c.HeureFin, out var fin) && TimeSpan.TryParse(c.HeureDebut, out var debut))
                    total += (fin - debut).TotalHours;
            }
            return $"{total:0.#}h";
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            // Récupérer l'ID de l'enseignant depuis localStorage (mis par le login)
            var enseignantId = await JS.InvokeAsync<string>("localStorage.getItem", "userId");
            if (!string.IsNullOrEmpty(enseignantId))
            {
                creneaux = await Http.GetFromJsonAsync<List<CreneauDto>>($"api/Creneaux/enseignant/{enseignantId}") ?? new();
                StateHasChanged();
            }
        }
    }

    public class CreneauDto
    {
        public int     Id            { get; set; }
        public string  CoursNom      { get; set; } = "";
        public string  GroupeNom     { get; set; } = "";
        public int     JourSemaine   { get; set; }
        public string  HeureDebut    { get; set; } = "";
        public string  HeureFin      { get; set; } = "";
        public string? Salle         { get; set; }
    }
}
