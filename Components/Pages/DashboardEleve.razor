@page "/dashboard-eleve"
@rendermode InteractiveServer

@inject HttpClient Http
@inject NavigationManager Navigation
@inject IJSRuntime JS

@if (nomEleve != null)
{
    <div class="sk-welcome">
        <div class="sk-welcome-avatar">@GetInitiales(nomEleve)</div>
        <div>
            <h2 class="sk-welcome-title">Bonjour, @nomEleve !</h2>
            <p class="sk-welcome-sub">Tableau de bord élève</p>
        </div>
    </div>
}

<div class="sk-section-title">Mes accès rapides</div>

<div class="sk-action-grid">
    <div class="sk-action-card" @onclick="GoDossier">
        <div class="sk-action-icon">📂</div>
        <div class="sk-action-title">Mon dossier académique</div>
        <div class="sk-action-desc">Voir mes inscriptions, cours et progression</div>
    </div>

    <div class="sk-action-card sk-action-card-soon">
        <div class="sk-action-icon">📅</div>
        <div class="sk-action-title">Mon horaire</div>
        <div class="sk-action-desc coming-soon">Bientôt disponible</div>
    </div>

    <div class="sk-action-card sk-action-card-soon">
        <div class="sk-action-icon">📝</div>
        <div class="sk-action-title">Mes notes</div>
        <div class="sk-action-desc coming-soon">Bientôt disponible</div>
    </div>

    <div class="sk-action-card sk-action-card-soon">
        <div class="sk-action-icon">📋</div>
        <div class="sk-action-title">Mes absences</div>
        <div class="sk-action-desc coming-soon">Bientôt disponible</div>
    </div>
</div>

@code {
    private string? nomEleve;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            nomEleve = await JS.InvokeAsync<string>(
                "localStorage.getItem",
                "nom"
            ) ?? "Élève";

            StateHasChanged();
        }
    }

    private string GetInitiales(string nom)
    {
        if (string.IsNullOrWhiteSpace(nom))
            return "E";

        var parts = nom.Trim().Split(' ');

        return parts.Length >= 2
            ? $"{parts[0][0]}{parts[^1][0]}".ToUpper()
            : nom[0].ToString().ToUpper();
    }

    private void GoDossier()
    {
        Navigation.NavigateTo("/dossier-academique");
    }
}