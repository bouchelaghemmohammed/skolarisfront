@page "/admin/cours"
@inject HttpClient Http
@using System.Net.Http.Json
@inject NavigationManager Navigation

<h3>Liste des cours</h3>

<button class="btn btn-primary" @onclick='() => Navigation.NavigateTo("/admin/cours/create")'>
    ➕ Créer un cours
</button>

<br />
<br />


@if (coursList == null)
{
    <p>Chargement...</p>
}
else if (!coursList.Any())
{
    <p>Aucun cours trouvé</p>
}
else
{
    <table class="table">
        <thead>
            <tr>
                <th>ID</th>
                <th>Code</th>
                <th>Nom</th>
                <th>Description</th>
                <th>ProgrammeId</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var c in coursList)
            {
                <tr>
                    <td>@c.Id</td>
                    <td>@c.Code</td>
                    <td>@c.Nom</td>
                    <td>@c.Description</td>
                    <td>@c.ProgrammeId</td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    List<Cours>? coursList;

    protected override async Task OnInitializedAsync()
    {
        coursList = await Http.GetFromJsonAsync<List<Cours>>("api/Cours");
    }

    public class Cours
    {
        public int Id { get; set; }
        public string Code { get; set; } = "";
        public string Nom { get; set; } = "";
        public string Description { get; set; } = "";
        public int ProgrammeId { get; set; }
    }
}