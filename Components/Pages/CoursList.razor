@page "/admin/cours"
@rendermode InteractiveServer
@inject HttpClient Http
@inject NavigationManager Navigation
@using System.Net.Http.Json

@if (!loaded)
{
    <div class="sk-loading">Chargement des cours...</div>
}
else
{
    <div class="sk-dossier-header">
        <div class="sk-dossier-avatar">📘</div>
        <div>
            <h2 class="sk-dossier-name">Gestion des cours</h2>
            <p class="sk-dossier-sub">Administration — Catalogue de cours</p>
        </div>
    </div>

    <div class="sk-stats-row">
        <div class="sk-stat-card">
            <div class="sk-stat-icon">📘</div>
            <div class="sk-stat-value">@coursList.Count</div>
            <div class="sk-stat-label">Total cours</div>
        </div>
        <div class="sk-stat-card sk-stat-card-blue">
            <div class="sk-stat-icon">📚</div>
            <div class="sk-stat-value">@coursList.Select(c => c.ProgrammeId).Distinct().Count()</div>
            <div class="sk-stat-label">Programmes</div>
        </div>
    </div>

    <div class="sk-section-title" style="margin-top:32px;">Liste des cours</div>

    <div class="mb-3">
        <button class="sk-btn sk-btn-primary" @onclick='() => Navigation.NavigateTo("/admin/cours/create")'>
            ➕ Créer un cours
        </button>
    </div>

    @if (!coursList.Any())
    {
        <div class="sk-empty">Aucun cours trouvé.</div>
    }
    else
    {
        <div class="sk-table-wrapper">
            <table class="sk-table">
                <thead>
                    <tr>
                        <th>Code</th>
                        <th>Nom</th>
                        <th>Description</th>
                        <th>Programme</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var c in coursList)
                    {
                        <tr>
                            <td><code class="sk-code">@c.Code</code></td>
                            <td><strong>@c.Nom</strong></td>
                            <td>@(string.IsNullOrEmpty(c.Description) ? "—" : c.Description)</td>
                            <td><span class="sk-badge sk-badge-info">Programme #@c.ProgrammeId</span></td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
}

<div class="mt-4">
    <button class="sk-btn sk-btn-outline" @onclick='() => Navigation.NavigateTo("/dashboard-admin")'>← Retour au tableau de bord</button>
</div>

@code {
    private List<Cours> coursList = new();
    private bool loaded = false;

    protected override async Task OnInitializedAsync()
    {
        coursList = await Http.GetFromJsonAsync<List<Cours>>("api/Cours") ?? new();
        loaded = true;
    }

    public class Cours
    {
        public int Id { get; set; }
        public string Code { get; set; } = "";
        public string Nom { get; set; } = "";
        public string Description { get; set; } = "";
        public int ProgrammeId { get; set; }
    }
}
