@page "/admin/inscriptions"
@rendermode InteractiveServer
@inject HttpClient Http
@inject NavigationManager Navigation
@inject IJSRuntime JS
@using System.Net.Http.Json
@using Microsoft.AspNetCore.WebUtilities

@if (!loaded)
{
    <div class="sk-loading">Chargement des inscriptions...</div>
}
else
{
    <div class="sk-dossier-header">
        <div class="sk-dossier-avatar">📝</div>
        <div>
            <h2 class="sk-dossier-name">Gestion des inscriptions</h2>
            <p class="sk-dossier-sub">Administration — Inscriptions aux cours</p>
        </div>
    </div>

    <div class="sk-stats-row">
        <div class="sk-stat-card">
            <div class="sk-stat-icon">📝</div>
            <div class="sk-stat-value">@inscriptions.Count</div>
            <div class="sk-stat-label">Total inscriptions</div>
        </div>
        <div class="sk-stat-card sk-stat-card-blue">
            <div class="sk-stat-icon">🎓</div>
            <div class="sk-stat-value">@inscriptions.Select(i => i.IdEleve).Distinct().Count()</div>
            <div class="sk-stat-label">Élèves inscrits</div>
        </div>
        <div class="sk-stat-card sk-stat-card-accent">
            <div class="sk-stat-icon">📚</div>
            <div class="sk-stat-value">@inscriptions.Select(i => i.IdCoursOffert).Distinct().Count()</div>
            <div class="sk-stat-label">Cours concernés</div>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(message))
    {
        <div class="sk-alert @(message.StartsWith("❌") ? "sk-alert-danger" : "sk-alert-success")">@message</div>
    }

    <div class="sk-section-title" style="margin-top:32px;">Liste des inscriptions</div>

    <div class="mb-3 d-flex gap-3 align-items-end flex-wrap">
        <button class="sk-btn sk-btn-primary" @onclick='() => Navigation.NavigateTo("/admin/inscriptions/create")'>
            ➕ Nouvelle inscription
        </button>
        <div>
            <label class="form-label mb-1">Filtrer par élève</label>
            <select class="form-select" @bind="filtreEleveId" @bind:after="AppliquerFiltres">
                <option value="0">Tous</option>
                @foreach (var e in eleves)
                {
                    <option value="@e.IdEleve">@e.Prenom @e.Nom (@e.Matricule)</option>
                }
            </select>
        </div>
        <div>
            <label class="form-label mb-1">Filtrer par cours</label>
            <select class="form-select" @bind="filtreCoursId" @bind:after="AppliquerFiltres">
                <option value="0">Tous</option>
                @foreach (var c in coursOfferts)
                {
                    <option value="@c.IdCoursOffert">
                        @(string.IsNullOrEmpty(c.NomCours) ? $"Cours #{c.IdCoursOffert}" : c.NomCours)
                    </option>
                }
            </select>
        </div>
    </div>

    @if (!inscriptionsFiltrees.Any())
    {
        <div class="sk-empty">Aucune inscription trouvée.</div>
    }
    else
    {
        <div class="sk-table-wrapper">
            <table class="sk-table">
                <thead>
                    <tr>
                        <th>Date</th>
                        <th>Élève</th>
                        <th>Cours offert</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var i in inscriptionsFiltrees.OrderByDescending(i => i.DateInscription))
                    {
                        <tr>
                            <td>@i.DateInscription.ToString("yyyy-MM-dd")</td>
                            <td>@GetEleveLabel(i.IdEleve)</td>
                            <td>@GetCoursLabel(i.IdCoursOffert)</td>
                            <td class="sk-actions">
                                <button class="sk-btn sk-btn-sm sk-btn-danger" @onclick="() => DeleteInscription(i.IdInscription)">Supprimer</button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
}

<div class="mt-4">
    <button class="sk-btn sk-btn-outline" @onclick='() => Navigation.NavigateTo("/dashboard-admin")'>← Retour au tableau de bord</button>
</div>

@code {
    private List<Inscription> inscriptions = new();
    private List<Inscription> inscriptionsFiltrees = new();
    private List<EleveDto> eleves = new();
    private List<CoursOffertDto> coursOfferts = new();
    private string message = "";
    private bool loaded = false;

    private int filtreEleveId = 0;
    private int filtreCoursId = 0;

    protected override async Task OnInitializedAsync()
    {
        var uri = Navigation.ToAbsoluteUri(Navigation.Uri);
        if (QueryHelpers.ParseQuery(uri.Query).TryGetValue("created", out var created) && created == "true")
            message = "✅ Inscription créée avec succès!";

        await ChargerDonnees();
        loaded = true;
    }

    private async Task ChargerDonnees()
    {
        try
        {
            var inscriptionsTask = Http.GetFromJsonAsync<List<Inscription>>("api/inscriptions");
            var elevesTask = Http.GetFromJsonAsync<List<EleveDto>>("api/eleves");
            var coursTask = Http.GetFromJsonAsync<List<CoursOffertDto>>("api/CoursOffert");

            await Task.WhenAll(inscriptionsTask, elevesTask, coursTask);

            inscriptions = inscriptionsTask.Result ?? new();
            eleves = elevesTask.Result ?? new();
            coursOfferts = coursTask.Result ?? new();
        }
        catch
        {
            inscriptions = new();
            eleves = new();
            coursOfferts = new();
        }

        AppliquerFiltres();
    }

    private void AppliquerFiltres()
    {
        inscriptionsFiltrees = inscriptions
            .Where(i => filtreEleveId == 0 || i.IdEleve == filtreEleveId)
            .Where(i => filtreCoursId == 0 || i.IdCoursOffert == filtreCoursId)
            .ToList();
    }

    private string GetEleveLabel(int idEleve)
    {
        var e = eleves.FirstOrDefault(x => x.IdEleve == idEleve);
        return e == null ? $"#{idEleve}" : $"{e.Prenom} {e.Nom} ({e.Matricule})";
    }

    private string GetCoursLabel(int idCoursOffert)
    {
        var c = coursOfferts.FirstOrDefault(x => x.IdCoursOffert == idCoursOffert);
        if (c == null) return $"Cours #{idCoursOffert}";
        return !string.IsNullOrEmpty(c.NomCours)
            ? $"{c.NomCours} ({c.ModeEnseignement})"
            : $"Cours #{idCoursOffert} ({c.ModeEnseignement})";
    }

    private async Task DeleteInscription(int id)
    {
        bool confirmation = await JS.InvokeAsync<bool>("confirm", "Supprimer cette inscription ?");
        if (!confirmation) return;

        var res = await Http.DeleteAsync($"api/inscriptions/{id}");
        if (res.IsSuccessStatusCode)
        {
            message = "✅ Inscription supprimée.";
            inscriptions = inscriptions.Where(i => i.IdInscription != id).ToList();
            AppliquerFiltres();
        }
        else
        {
            message = "❌ Erreur suppression.";
        }
    }

    public class Inscription
    {
        public int IdInscription { get; set; }
        public int IdEleve { get; set; }
        public int IdCoursOffert { get; set; }
        public DateTime DateInscription { get; set; }
    }

    public class EleveDto
    {
        public int IdEleve { get; set; }
        public string Matricule { get; set; } = "";
        public string Nom { get; set; } = "";
        public string Prenom { get; set; } = "";
    }

    public class CoursOffertDto
    {
        public int IdCoursOffert { get; set; }
        public string? NomCours { get; set; }
        public string ModeEnseignement { get; set; } = "";
    }
}
