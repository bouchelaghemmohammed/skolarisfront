@page "/users-management"
@rendermode InteractiveServer
@inject HttpClient Http
@inject NavigationManager Navigation
@inject IJSRuntime JS

@if (!loaded)
{
    <div class="sk-loading">Chargement des utilisateurs...</div>
}
else
{
    <div class="sk-dossier-header">
        <div class="sk-dossier-avatar">👥</div>
        <div>
            <h2 class="sk-dossier-name">Gestion des utilisateurs</h2>
            <p class="sk-dossier-sub">Administration — Comptes, rôles et accès</p>
        </div>
    </div>

    <div class="sk-stats-row">
        <div class="sk-stat-card">
            <div class="sk-stat-icon">👥</div>
            <div class="sk-stat-value">@users.Count</div>
            <div class="sk-stat-label">Total utilisateurs</div>
        </div>
        <div class="sk-stat-card sk-stat-card-blue">
            <div class="sk-stat-icon">📖</div>
            <div class="sk-stat-value">@users.Count(u => u.Role == "ENSEIGNANT")</div>
            <div class="sk-stat-label">Enseignants</div>
        </div>
        <div class="sk-stat-card sk-stat-card-accent">
            <div class="sk-stat-icon">🎓</div>
            <div class="sk-stat-value">@users.Count(u => u.Role == "ELEVE")</div>
            <div class="sk-stat-label">Élèves</div>
        </div>
        <div class="sk-stat-card sk-stat-card-green">
            <div class="sk-stat-icon">✅</div>
            <div class="sk-stat-value">@users.Count(u => u.IsActive)</div>
            <div class="sk-stat-label">Actifs</div>
        </div>
        <div class="sk-stat-card sk-stat-card-warn">
            <div class="sk-stat-icon">🚫</div>
            <div class="sk-stat-value">@users.Count(u => !u.IsActive)</div>
            <div class="sk-stat-label">Désactivés</div>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="sk-alert sk-alert-danger">@errorMessage</div>
    }
    @if (!string.IsNullOrEmpty(successMessage))
    {
        <div class="sk-alert sk-alert-success">@successMessage</div>
    }

    <div class="sk-section-title" style="margin-top:32px;">Liste des utilisateurs</div>

    <div class="sk-table-wrapper">
        <table class="sk-table">
            <thead>
                <tr>
                    <th>Nom</th>
                    <th>Courriel</th>
                    <th>Rôle</th>
                    <th>Changer rôle</th>
                    <th>Statut</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var user in users)
                {
                    <tr>
                        <td><strong>@user.Nom</strong></td>
                        <td>@user.Email</td>
                        <td><span class="sk-badge @GetRoleClass(user.Role)">@user.Role</span></td>
                        <td>
                            <div class="d-flex gap-2 align-items-center">
                                <select class="form-select form-select-sm" style="width:auto;" @bind="user.Role">
                                    <option value="ADMIN">ADMIN</option>
                                    <option value="ENSEIGNANT">ENSEIGNANT</option>
                                    <option value="ELEVE">ELEVE</option>
                                </select>
                                <button class="sk-btn sk-btn-sm sk-btn-primary" @onclick="() => ChangeRole(user)">Appliquer</button>
                            </div>
                        </td>
                        <td>
                            <span class="sk-badge @(user.IsActive ? "sk-badge-active" : "sk-badge-inactive")">
                                @(user.IsActive ? "Actif" : "Inactif")
                            </span>
                        </td>
                        <td class="sk-actions">
                            <button class="sk-btn sk-btn-sm sk-btn-outline" @onclick="() => OpenEdit(user)">Modifier</button>
                            <button class="sk-btn sk-btn-sm @(user.IsActive ? "sk-btn-warning" : "sk-btn-success")" @onclick="() => ToggleActive(user.Id)">
                                @(user.IsActive ? "Désactiver" : "Activer")
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @if (editUser != null)
    {
        <div class="sk-section-title" style="margin-top:32px;">Modifier le profil</div>
        <div class="card p-3" style="max-width:480px;">
            <input class="form-control mb-2" @bind="editUserPrenom" placeholder="Prénom" />
            <input class="form-control mb-2" @bind="editUserNom" placeholder="Nom" />
            <input class="form-control mb-2" @bind="editUserEmail" placeholder="Courriel" />
            <div class="d-flex gap-2">
                <button class="sk-btn sk-btn-primary" @onclick="SaveEdit">Enregistrer</button>
                <button class="sk-btn sk-btn-outline" @onclick="CancelEdit">Annuler</button>
            </div>
        </div>
    }
}

<div class="mt-4">
    <button class="sk-btn sk-btn-outline" @onclick='() => Navigation.NavigateTo("/dashboard-admin")'>← Retour au tableau de bord</button>
</div>

@code {
    private List<UserItem> users = new();
    private string errorMessage = "";
    private string successMessage = "";
    private bool loaded = false;

    private UserItem? editUser;
    private string editUserPrenom = "";
    private string editUserNom = "";
    private string editUserEmail = "";

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await LoadUsers();
            loaded = true;
            StateHasChanged();
        }
    }

    private async Task LoadUsers()
    {
        users = await Http.GetFromJsonAsync<List<UserItem>>("api/users") ?? new();
    }

    private async Task ToggleActive(int id)
    {
        errorMessage = "";
        successMessage = "";
        var response = await Http.PostAsync($"api/users/{id}/toggle-active", null);
        if (!response.IsSuccessStatusCode) { errorMessage = "Impossible de modifier ce compte."; return; }
        successMessage = "✅ Statut mis à jour.";
        await LoadUsers();
        StateHasChanged();
    }

    private async Task ChangeRole(UserItem user)
    {
        errorMessage = "";
        successMessage = "";
        var response = await Http.PostAsJsonAsync($"api/users/{user.Id}/change-role", new ChangeRoleRequest { Role = user.Role });
        if (!response.IsSuccessStatusCode) { errorMessage = "Impossible de modifier le rôle."; return; }
        successMessage = "✅ Rôle mis à jour.";
        await LoadUsers();
        StateHasChanged();
    }

    private void OpenEdit(UserItem u)
    {
        errorMessage = "";
        successMessage = "";
        editUser = u;
        var parts = u.Nom.Trim().Split(' ', 2);
        editUserPrenom = parts[0];
        editUserNom = parts.Length > 1 ? parts[1] : "";
        editUserEmail = u.Email;
    }

    private void CancelEdit() => editUser = null;

    private async Task SaveEdit()
    {
        if (editUser == null) return;
        errorMessage = "";
        successMessage = "";
        var res = await Http.PutAsJsonAsync($"api/profile/{editUser.Id}", new { Prenom = editUserPrenom, Nom = editUserNom, Email = editUserEmail });
        if (res.IsSuccessStatusCode)
        {
            successMessage = "✅ Profil mis à jour.";
            editUser = null;
            await LoadUsers();
            StateHasChanged();
        }
        else
        {
            errorMessage = await res.Content.ReadAsStringAsync();
        }
    }

    private string GetRoleClass(string role) => role switch
    {
        "ADMIN"      => "sk-badge-danger",
        "ENSEIGNANT" => "sk-badge-info",
        "ELEVE"      => "sk-badge-accent",
        _            => "sk-badge-info"
    };

    public class UserItem
    {
        public int Id { get; set; }
        public string Nom { get; set; } = "";
        public string Email { get; set; } = "";
        public string Role { get; set; } = "";
        public bool IsActive { get; set; }
    }

    public class ChangeRoleRequest
    {
        public string Role { get; set; } = "";
    }
}
