@inject NavigationManager Navigation
@inject IJSRuntime JS

<div class="sk-sidebar-brand" @onclick="GoHome">
    <div class="sk-sidebar-logo">S</div>
    <span class="sk-sidebar-name">Skolaris</span>
</div>

<nav class="sk-sidebar-nav">

    <div class="sk-nav-item" @onclick="GoHome">
        <span class="sk-nav-icon">🏠</span>
        <span>Accueil</span>
    </div>

    @if (role == "ADMIN")
    {
        <div class="sk-nav-section">Administration</div>

        <div class="sk-nav-item"
             @onclick='() => Navigation.NavigateTo("/users-management")'>
            <span class="sk-nav-icon">👥</span>
            <span>Utilisateurs</span>
        </div>

        <div class="sk-nav-item"
             @onclick='() => Navigation.NavigateTo("/etablissements")'>
            <span class="sk-nav-icon">🏫</span>
            <span>Établissements</span>
        </div>

        <div class="sk-nav-item"
             @onclick='() => Navigation.NavigateTo("/sessions")'>
            <span class="sk-nav-icon">📅</span>
            <span>Sessions</span>
        </div>

      /*  <div class="sk-nav-item"
             @onclick='() => Navigation.NavigateTo("/admin/programmes")'>
            <span class="sk-nav-icon">📚</span>
            <span>Programmes</span>
        </div>

        <div class="sk-nav-item"
             @onclick='() => Navigation.NavigateTo("/admin/cours")'>
            <span class="sk-nav-icon">📘</span>
            <span>Cours</span>
        </div>*/

        <div class="sk-nav-item"
             @onclick='() => Navigation.NavigateTo("/admin/inscriptions")'>
            <span class="sk-nav-icon">📝</span>
            <span>Inscriptions</span>
        </div>

        <div class="sk-nav-item"
             @onclick='() => Navigation.NavigateTo("/admin/absences")'>
            <span class="sk-nav-icon">🚫</span>
            <span>Absences</span>
        </div>

        <div class="sk-nav-item"
             @onclick='() => Navigation.NavigateTo("/admin/bulletins")'>
            <span class="sk-nav-icon">📄</span>
            <span>Bulletins</span>
        </div>

        <div class="sk-nav-item"
             @onclick='() => Navigation.NavigateTo("/admin/grilles")'>
            <span class="sk-nav-icon">📋</span>
            <span>Grilles d'évaluation</span>
        </div>

        <div class="sk-nav-item"
             @onclick='() => Navigation.NavigateTo("/programmes")'>
            <span class="sk-nav-icon">📄</span>
            <span>Programmes</span>
        </div>
        <div class="sk-nav-item"
             @onclick='() => Navigation.NavigateTo("/cours")'>
            <span class="sk-nav-icon">📄</span>
            <span>Cours</span>
        </div>


    }

    @if (role == "ENSEIGNANT")
    {
        <div class="sk-nav-section">Enseignant</div>

        <div class="sk-nav-item"
             @onclick='() => Navigation.NavigateTo("/enseignant/absences")'>
            <span class="sk-nav-icon">🚫</span>
            <span>Absences</span>
        </div>

        <div class="sk-nav-item"
             @onclick='() => Navigation.NavigateTo("/enseignant/notes")'>
            <span class="sk-nav-icon">📝</span>
            <span>Saisie des notes</span>
        </div>

        <div class="sk-nav-item"
             @onclick='() => Navigation.NavigateTo("/enseignant/statistiques")'>
            <span class="sk-nav-icon">📊</span>
            <span>Statistiques de classe</span>
        </div>
    }

    @if (role == "ELEVE")
    {
        <div class="sk-nav-section">Mon espace</div>

        <div class="sk-nav-item"
             @onclick='() => Navigation.NavigateTo("/dossier-academique")'>
            <span class="sk-nav-icon">📂</span>
            <span>Dossier académique</span>
        </div>

        <div class="sk-nav-item"
             @onclick='() => Navigation.NavigateTo("/eleve/absences")'>
            <span class="sk-nav-icon">🚫</span>
            <span>Absences</span>
        </div>

        <div class="sk-nav-item"
             @onclick='() => Navigation.NavigateTo("/eleve/notes")'>
            <span class="sk-nav-icon">📝</span>
            <span>Notes & bulletins</span>
        </div>
    }

</nav>

@code {

    private string role = "";

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            role = await JS.InvokeAsync<string>(
                "localStorage.getItem",
                "role"
            ) ?? "";

            StateHasChanged();
        }
    }

    private void GoHome()
    {
        if (role == "ADMIN")
            Navigation.NavigateTo("/dashboard-admin");

        else if (role == "ENSEIGNANT")
            Navigation.NavigateTo("/dashboard-enseignant");

        else if (role == "ELEVE")
            Navigation.NavigateTo("/dashboard-eleve");

        else
            Navigation.NavigateTo("/login");
    }
}