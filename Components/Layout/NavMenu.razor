@inject NavigationManager Navigation
@inject IJSRuntime JS

<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand" @onclick="GoHome">
            Skolaris
        </a>
    </div>
</div>

<input type="checkbox" title="Navigation menu" class="navbar-toggler" />

<div class="nav-scrollable" onclick="document.querySelector('.navbar-toggler').click()">
    <nav class="flex-column">

        <!-- HOME -->
        <div class="nav-item px-3">
            <a class="nav-link" @onclick="GoHome">
                <span class="bi bi-house-door-fill-nav-menu"></span>
                Home
            </a>
        </div>

        <!-- ADMIN SEULEMENT -->
        @if (role == "ADMIN")
        {
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="users-management">
                    <span class="bi bi-people-fill"></span>
                    Gérer les utilisateurs
                </NavLink>
            </div>
        }

    </nav>
</div>

@code {
    private string role = "";

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            role = await JS.InvokeAsync<string>("localStorage.getItem", "role") ?? "";
            StateHasChanged();
        }
    }

    private void GoHome()
    {
        if (role == "ADMIN")
            Navigation.NavigateTo("/dashboard-admin");
        else if (role == "ENSEIGNANT")
            Navigation.NavigateTo("/dashboard-enseignant");
        else if (role == "ELEVE")
            Navigation.NavigateTo("/dashboard-eleve");
        else
            Navigation.NavigateTo("/login");
    }
}