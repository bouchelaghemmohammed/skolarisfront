@inject NavigationManager Navigation
@inject IJSRuntime JS

<div class="sk-sidebar-brand" @onclick="GoHome">
    <div class="sk-sidebar-logo">S</div>
    <span class="sk-sidebar-name">Skolaris</span>
</div>

<nav class="sk-sidebar-nav">

    <div class="sk-nav-item" @onclick="GoHome">
        <span class="sk-nav-icon">🏠</span>
        <span>Accueil</span>
    </div>

    @if (role == "ADMIN")
    {
        <div class="sk-nav-section">Administration</div>

        <div class="sk-nav-item" @onclick='() => Navigation.NavigateTo("/users-management")'>
            <span class="sk-nav-icon">👥</span>
            <span>Utilisateurs</span>
        </div>

        <div class="sk-nav-item" @onclick='() => Navigation.NavigateTo("/etablissements")'>
            <span class="sk-nav-icon">🏫</span>
            <span>Établissements</span>
        </div>

        <div class="sk-nav-item" @onclick='() => Navigation.NavigateTo("/sessions")'>
            <span class="sk-nav-icon">📅</span>
            <span>Sessions</span>
        </div>
    }

    @if (role == "ELEVE")
    {
        <div class="sk-nav-section">Mon espace</div>

        <div class="sk-nav-item" @onclick='() => Navigation.NavigateTo("/dossier-academique")'>
            <span class="sk-nav-icon">📂</span>
            <span>Dossier académique</span>
        </div>
    }

</nav>

@code {
    private string role = "";

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            role = await JS.InvokeAsync<string>("localStorage.getItem", "role") ?? "";
            StateHasChanged();
        }
    }

    private void GoHome()
    {
        if (role == "ADMIN")
            Navigation.NavigateTo("/dashboard-admin");
        else if (role == "ENSEIGNANT")
            Navigation.NavigateTo("/dashboard-enseignant");
        else if (role == "ELEVE")
            Navigation.NavigateTo("/dashboard-eleve");
        else
            Navigation.NavigateTo("/login");
    }
}
